@bot.message_handler(func=lambda msg: msg.text and msg.text.startswith("http") and "platorelay" in msg.text.lower())
def handle_bypass_with_playwright(message):
    user_id = message.from_user.id
    
    if not check_subscription(user_id):
        show_subscription_warning(message)
        return
    
    url = message.text.strip()
    
    # Сообщение "Байпас начался..."
    status_msg = bot.reply_to(
        message,
        "⏳ *Байпас начался, ожидайте...*\n\n"
        "Идёт обход системы защиты...\n"
        "Это может занять 30-60 секунд.",
        parse_mode="Markdown"
    )
    
    start_time = time.time()
    
    # Запускаем обход в отдельном потоке (чтобы не блокировать бота)
    def run_bypass():
        try:
            # Запускаем асинхронную функцию в синхронном контексте
            loop = asyncio.new_event_loop()
            asyncio.set_event_loop(loop)
            key = loop.run_until_complete(bypass_platorelay_with_playwright(url))
            loop.close()
            
            elapsed = round(time.time() - start_time, 2)
            
            if key:
                # Успешный обход
                keyboard = types.InlineKeyboardMarkup(row_width=1)
                
                btn_copy = types.InlineKeyboardButton(
                    "Скопировать ключ",
                    callback_data=f"copy_{key}",
                    style="success"
                )
                
                btn_menu = types.InlineKeyboardButton(
                    "Главное меню",
                    callback_data="main_menu"
                )
                
                keyboard.add(btn_copy, btn_menu)
                
                bot.edit_message_text(
                    text=(
                        "✅ *Байпас успешен!*\n\n"
                        "📌 *Результат:*\n"
                        f"`{key}`\n\n"
                        f"⏱ *Затрачено:* {elapsed} сек."
                    ),
                    chat_id=message.chat.id,
                    message_id=status_msg.message_id,
                    parse_mode="Markdown",
                    reply_markup=keyboard
                )
            else:
                # Ключ не найден
                keyboard = types.InlineKeyboardMarkup(row_width=1)
                btn_menu = types.InlineKeyboardButton(
                    "Главное меню",
                    callback_data="main_menu"
                )
                keyboard.add(btn_menu)
                
                bot.edit_message_text(
                    text=(
                        f"❌ *Ключ не найден*\n\n"
                        "Не удалось получить ключ.\n"
                        "Возможные причины:\n"
                        "• Ссылка устарела\n"
                        "• Сайт требует ручную капчу\n"
                        "• Система защиты слишком сложная\n\n"
                        f"⏱ *Затрачено:* {elapsed} сек.\n\n"
                        "📁 Сохранены файлы для отладки:\n"
                        "• debug_page.png\n"
                        "• debug_page.html"
                    ),
                    chat_id=message.chat.id,
                    message_id=status_msg.message_id,
                    parse_mode="Markdown",
                    reply_markup=keyboard
                )
        except Exception as e:
            elapsed = round(time.time() - start_time, 2)
            keyboard = types.InlineKeyboardMarkup(row_width=1)
            btn_menu = types.InlineKeyboardButton(
                "Главное меню",
                callback_data="main_menu"
            )
            keyboard.add(btn_menu)
            
            bot.edit_message_text(
                text=(
                    f"❌ *Ошибка обхода*\n\n"
                    f"{str(e)}\n\n"
                    f"⏱ *Затрачено:* {elapsed} сек."
                ),
                chat_id=message.chat.id,
                message_id=status_msg.message_id,
                parse_mode="Markdown",
                reply_markup=keyboard
            )
    
    # Запускаем в отдельном потоке
    threading.Thread(target=run_bypass, daemon=True).start()

# ===== ОБРАБОТКА ССЫЛОК (получение скрипта) =====
@bot.message_handler(func=lambda msg: msg.text and msg.text.startswith("http") and "platorelay" not in msg.text.lower())
def handle_script_request(message):
    user_id = message.from_user.id
    
    if not check_subscription(user_id):
        show_subscription_warning(message)
        return
    
    url = message.text.strip()
    status_msg = bot.reply_to(message, "⏳ *Получение скрипта...*", parse_mode="Markdown")
    
    try:
        script = fetch_script_from_url(url)
        
        if script:
            keyboard = types.InlineKeyboardMarkup(row_width=1)
            btn_menu = types.InlineKeyboardButton(
                "Главное меню",
                callback_data="main_menu"
            )
            keyboard.add(btn_menu)
            
            if len(script) > 4000:
                filename = f"script_{user_id}_{int(time.time())}.lua"
                with open(filename, "w", encoding="utf-8") as f:
                    f.write(script)
                
                with open(filename, "rb") as f:
                    bot.send_document(
                        message.chat.id,
                        f,
                        caption=f"✅ *Скрипт получен!*\n\nИсточник: {url}",
                        parse_mode="Markdown",
                        reply_markup=keyboard
                    )
                
                os.remove(filename)
                bot.delete_message(message.chat.id, status_msg.message_id)
            else:
                bot.edit_message_text(
                    text=(
                        f"✅ *Скрипт получен!*\n\n"
                        f"Источник: {url}\n\n"
                        f"```lua\n{script}\n```"
                    ),
                    chat_id=message.chat.id,
                    message_id=status_msg.message_id,
                    parse_mode="Markdown",
                    reply_markup=keyboard
                )
        else:
            keyboard = types.InlineKeyboardMarkup(row_width=1)
            btn_menu = types.InlineKeyboardButton(
                "Главное меню",
                callback_data="main_menu"
            )
            keyboard.add(btn_menu)
            
            bot.edit_message_text(
                text=(
                    f"❌ *Ошибка получения скрипта*\n\n"
                    f"Не удалось получить скрипт по ссылке:\n"
                    f"`{url}`\n\n"
                    "Проверьте, что ссылка ведёт на raw-файл."
                ),
                chat_id=message.chat.id,
                message_id=status_msg.message_id,
                parse_mode="Markdown",
                reply_markup=keyboard
            )
    except Exception as e:
        keyboard = types.InlineKeyboardMarkup(row_width=1)
        btn_menu = types.InlineKeyboardButton(
            "Главное меню",
            callback_data="main_menu"
        )
        keyboard.add(btn_menu)
        
        bot.edit_message_text(
            text=f"❌ *Ошибка*\n\n{str(e)}",
            chat_id=message.chat.id,
            message_id=status_msg.message_id,
            parse_mode="Markdown",
            reply_markup=keyboard
        )

